# BASE CONFIG

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Environment type - determines security settings, domains, and service URLs
# Options: development, staging, production
ENVIRONMENT=development

# Django secret key - generate a new one for production
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY='your-secret-key-here'

# External user password for API access
EXTERNAL_PASS='your-external-password-here'

# =============================================================================
# TIME ZONE CONFIGURATION
# =============================================================================

TIME_ZONE=Australia/Perth
TZ=Australia/Perth

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cannabis

# =============================================================================
# PRINCE XML CONFIGURATION
# =============================================================================

# PrinceXML license details for PDF generation
# Contact PrinceXML for license information
PRINCE_LICENSE_ID=your-license-id
PRINCE_LICENSE_SIGNATURE=your-license-signature
PRINCE_SERVER_URL=/usr/src/app/backend

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email settings for sending notifications
DEFAULT_FROM_EMAIL='Cannabis <cannabis-noreply@example.com>'
MAINTAINER_EMAIL='maintainer@dbca.wa.gov.au'

# For development, use the console backend to print emails to stdout:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP relay config (production uses mail-relay.lan.fyi by default)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587

# =============================================================================
# SITE URL
# =============================================================================

# Local development URL for the frontend
SITE_URL=http://127.0.0.1:3000

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Sentry DSN for error tracking (optional - leave empty if not using Sentry)
# Format: https://examplePublicKey@o0.ingest.sentry.io/0
# Leave empty or comment out if not using Sentry
# SENTRY_URL=

# =============================================================================
# EXTERNAL API INTEGRATIONS
# =============================================================================

# IT Assets API configuration for user search (invitations)
IT_ASSETS_ACCESS_TOKEN=your-it-assets-token-here
IT_ASSETS_USER=your-email@example.com
IT_ASSETS_URL=https://itassets-uat.dbca.wa.gov.au/api/v3/departmentuser/

# =============================================================================
# REDIS CACHE (optional - falls back to in-memory if not set)
# =============================================================================

# Redis URL for shared caching and rate limiting
# REDIS_URL=redis://localhost:6379/1

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Update all placeholder values with your actual configuration
# 3. Generate a new SECRET_KEY for production environments
# 4. Never commit .env to version control (it's in .gitignore)
# 5. For production/staging, use environment-specific files (.env.production, .env.staging)
